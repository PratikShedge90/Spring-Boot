<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="pass" name="com.tca.entities.Passport">
    <property name="pid" value="872093298018"/>
    <property name="country" value="India"/>
    <property name="colour" value="Dark-Blue"/>
    </bean>
    
    <bean id="student" name="com.tca.entities.Student">
    <constructor-arg name="rno" value="101"/>
    <constructor-arg name="name" value="Pratik Shedge"/>
    <constructor-arg name="fees" value="20000"/>
    
    <property name="passport" ref="pass"></property>
    </bean>
	
	
</beans>