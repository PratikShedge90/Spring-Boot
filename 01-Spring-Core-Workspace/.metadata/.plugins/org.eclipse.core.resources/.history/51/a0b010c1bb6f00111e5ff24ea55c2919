package com.cdac;

import org.springframework.context.ApplicationContext;
import org.springframework.context.support.ClassPathXmlApplicationContext;

public class App {
    public static void main(String[] args) 
    {
    	/** Step 1 : Creating and Starting Container */
        ApplicationContext context = new ClassPathXmlApplicationContext("config.xml");
       
        /** Step 2: Get the object of Bean  */
	/*	Object obj = context.getBean("welcome"); 
        Welcome wel = (Welcome) obj;
    */  
        Welcome wel = (Welcome)context.getBean(Welcome.class);
        
        Welcome wel2 = (Welcome)context.getBean(("welcome"));
        
        if(wel == wel2) {
        	System.out.println("Singleton DP !!" + wel.hashCode()  + "  "+ wel2.hashCode());
        }else {
        	System.out.println("Not SDP");
        }
        
        System.out.println(wel.message());
        
    }
}
