<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <!--<bean id="welcome" class="com.cdac.Welcome"></bean> -->
    
    <bean id="addr" class="com.tca.entities.Address">
    <constructor-arg name="city" value="FC-Pune-City"></constructor-arg>
    <constructor-arg name="pincode" value="410205"></constructor-arg>
    </bean>
    
    <bean id="customer" class="com.tca.entities.Customer">
    <constructor-arg name="cid" value="111"></constructor-arg>
    <constructor-arg name="name" value="Pratik Shedage"> </constructor-arg>
    <constructor-arg name="address" ref="addr" ></constructor-arg>
    </bean>

</beans>